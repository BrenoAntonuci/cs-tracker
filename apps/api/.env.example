# Neon PostgreSQL — pegue em console.neon.tech > seu projeto > Connection Details > Prisma
# DATABASE_URL usa o pooler (porta 6543) para queries da aplicação
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=10
# DIRECT_URL usa conexão direta (porta 5432) apenas para migrations
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&connect_timeout=10

# Steam Web API — gere em steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# JWT — qualquer string longa e aleatória
JWT_SECRET=a_very_long_random_secret_change_in_production

STEAM_RETURN_URL=http://localhost:3001/auth/steam/callback
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
